.category-page {
  padding-top: 88rpx;
}

.tool-center-head {
  height: 76rpx;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
}

.head-spacer {
  width: 72rpx;
}

.tool-center-title {
  text-align: center;
  color: #0F172A;
  font-size: 36rpx;
  font-weight: 900;
}

.filter-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  justify-self: end;
}

.search-box {
  margin-top: 8rpx;
}

.category-tabs-scroll {
  margin-top: 24rpx;
  width: 100%;
  white-space: nowrap;
}

.category-tabs-line {
  display: inline-flex;
  gap: 14rpx;
}

.category-tab {
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #344054;
  background: #FFFFFF;
  border: 1rpx solid #E7EEF8;
  font-size: 23rpx;
  box-sizing: border-box;
}

.category-tab.active {
  color: #FFFFFF;
  background: #0A7BFF;
  border-color: #0A7BFF;
  font-weight: 800;
  box-shadow: 0 10rpx 24rpx rgba(10, 123, 255, .22);
}

.search-result-tip {
  margin-bottom: 16rpx;
  color: #667085;
  font-size: 23rpx;
}

.search-empty {
  padding: 48rpx 32rpx;
  text-align: center;
}

.search-empty-title {
  color: #344054;
  font-size: 28rpx;
  font-weight: 800;
}

.search-empty-desc {
  margin-top: 12rpx;
  color: #8A94A6;
  font-size: 23rpx;
  line-height: 1.5;
}

.tool-list {
  margin-top: 0;
  display: grid;
  gap: 20rpx;
}

.tool-list-card {
  min-height: 146rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.tool-info {
  min-width: 0;
  flex: 1;
  margin-left: 24rpx;
}

.tool-list-name {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.tool-list-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tool-safe {
  margin-top: 8rpx;
  color: #8A94A6;
  font-size: 22rpx;
}

.use-pill {
  width: 126rpx;
  height: 50rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #0A7BFF;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(10, 123, 255, .22);
  flex-shrink: 0;
}

.local-note {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  color: #52647A;
  font-size: 23rpx;
  line-height: 1.6;
}
