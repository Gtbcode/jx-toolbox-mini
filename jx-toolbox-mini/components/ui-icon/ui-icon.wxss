.ui-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ui-icon.size-sm { width: 28rpx; height: 28rpx; }
.ui-icon.size-md { width: 34rpx; height: 34rpx; }
.ui-icon.size-lg { width: 42rpx; height: 42rpx; }
.ui-icon.size-xl { width: 82rpx; height: 82rpx; }
.ui-icon.size-xxl { width: 56rpx; height: 56rpx; }

.ui-icon.color-blue { color: #0A7BFF; }
.ui-icon.color-green { color: #12A37F; }
.ui-icon.color-red { color: #FF4F67; }
.ui-icon.color-gray { color: #8A94A6; }
.ui-icon.color-white { color: #FFFFFF; }

.glyph {
  position: relative;
  width: 100%;
  height: 100%;
}

/* search */
.search-emoji {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  line-height: 1;
}

.size-sm .search-emoji {
  font-size: 24rpx;
}

.size-md .search-emoji {
  font-size: 28rpx;
}

.size-lg .search-emoji {
  font-size: 34rpx;
}

/* tag */
.tag-body {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 22rpx;
  margin: -11rpx 0 0 -13rpx;
  border-radius: 5rpx 5rpx 5rpx 2rpx;
  background: currentColor;
  transform: rotate(-45deg);
}

.tag-hole {
  position: absolute;
  left: 8rpx;
  top: 10rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

/* gift */
.gift-box {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 20rpx;
  margin: -4rpx 0 0 -12rpx;
  border-radius: 4rpx;
  background: currentColor;
  opacity: .9;
}

.gift-ribbon-v,
.gift-ribbon-h {
  position: absolute;
  background: rgba(255, 255, 255, .85);
}

.gift-ribbon-v {
  left: 50%;
  top: 8rpx;
  width: 4rpx;
  height: 24rpx;
  margin-left: -2rpx;
}

.gift-ribbon-h {
  left: 6rpx;
  top: 50%;
  width: 22rpx;
  height: 4rpx;
  margin-top: -2rpx;
}

.gift-bow {
  position: absolute;
  left: 50%;
  top: 4rpx;
  width: 12rpx;
  height: 8rpx;
  margin-left: -6rpx;
  border-radius: 8rpx 8rpx 0 0;
  border: 3rpx solid currentColor;
  border-bottom: none;
  box-sizing: border-box;
}

/* shield-check */
.shield-check {
  position: relative;
}

.sc-shield {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 24rpx;
  transform: translate(-50%, -50%);
  background: currentColor;
  border-radius: 4rpx 4rpx 11rpx 11rpx;
  opacity: .2;
}

.color-green .sc-shield {
  opacity: .24;
}

.color-blue .sc-shield {
  opacity: .16;
}

.sc-tick-mark {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 7rpx;
  height: 11rpx;
  transform: translate(-50%, -58%) rotate(45deg);
  border-right: 2.5rpx solid currentColor;
  border-bottom: 2.5rpx solid currentColor;
  box-sizing: border-box;
}

.size-sm .sc-shield {
  width: 18rpx;
  height: 20rpx;
  border-radius: 3rpx 3rpx 9rpx 9rpx;
}

.size-sm .sc-tick-mark {
  width: 6rpx;
  height: 9rpx;
  transform: translate(-50%, calc(-50% + 2rpx)) rotate(45deg);
  border-right-width: 2rpx;
  border-bottom-width: 2rpx;
}

.size-md .sc-tick-mark {
  width: 7rpx;
  height: 11rpx;
  transform: translate(-50%, -56%) rotate(45deg);
}

.size-xl .sc-shield {
  width: 48rpx;
  height: 54rpx;
  border-radius: 8rpx 8rpx 24rpx 24rpx;
  opacity: .15;
}

.size-xl .sc-tick-mark {
  width: 14rpx;
  height: 22rpx;
  transform: translate(-50%, -56%) rotate(45deg);
  border-width: 5rpx;
}

/* shield plain */
.shield-shape {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 24rpx;
  margin-left: -11rpx;
  margin-top: -12rpx;
  background: currentColor;
  border-radius: 4rpx 4rpx 11rpx 11rpx;
  opacity: .92;
}

/* lightning */
.bolt {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 22rpx;
  margin: -11rpx 0 0 -7rpx;
  background: currentColor;
  clip-path: polygon(55% 0, 100% 0, 45% 52%, 72% 52%, 18% 100%, 38% 48%, 10% 48%);
}

/* filter */
.filter-top {
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 0;
  height: 0;
  margin-left: -12rpx;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid currentColor;
}

.filter-stem {
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 4rpx;
  height: 12rpx;
  margin-left: -2rpx;
  background: currentColor;
  border-radius: 2rpx;
}

/* clock */
.clock-face {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 26rpx;
  height: 26rpx;
  margin: -13rpx 0 0 -13rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.clock-hand {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 3rpx;
  height: 10rpx;
  margin: -10rpx 0 0 -1.5rpx;
  background: currentColor;
  border-radius: 2rpx;
}

/* heart */
.heart-shape {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  margin: -8rpx 0 0 -9rpx;
  background: currentColor;
  transform: rotate(-45deg);
  border-radius: 0 0 0 6rpx;
}

.heart-shape::before,
.heart-shape::after {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: currentColor;
}

.heart-shape::before { top: -9rpx; left: 0; }
.heart-shape::after { top: 0; left: 9rpx; }

/* doc */
.doc-page {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 28rpx;
  margin: -14rpx 0 0 -11rpx;
  border-radius: 4rpx;
  background: currentColor;
  opacity: .18;
}

.doc-line {
  position: absolute;
  left: 50%;
  height: 3rpx;
  margin-left: -8rpx;
  background: currentColor;
  border-radius: 2rpx;
}

.doc-line.l1 { top: 12rpx; width: 12rpx; }
.doc-line.l2 { top: 20rpx; width: 16rpx; }

/* chat */
.chat-bubble {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 20rpx;
  margin: -12rpx 0 0 -14rpx;
  border-radius: 10rpx;
  background: currentColor;
  opacity: .18;
}

.chat-dot {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
}

.chat-dot.d1 { left: 10rpx; top: 14rpx; }
.chat-dot.d2 { left: 15rpx; top: 14rpx; }
.chat-dot.d3 { left: 20rpx; top: 14rpx; }

/* info */
.info-circle {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 26rpx;
  height: 26rpx;
  margin: -13rpx 0 0 -13rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.info-i {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: currentColor;
  font-size: 18rpx;
  font-weight: 900;
  font-style: italic;
  line-height: 1;
}

/* rocket */
.rocket-body {
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 12rpx;
  height: 22rpx;
  margin-left: -6rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: currentColor;
}

.rocket-wing {
  position: absolute;
  bottom: 6rpx;
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
}

.rocket-wing.l {
  left: 4rpx;
  border-right: 8rpx solid currentColor;
}

.rocket-wing.r {
  right: 4rpx;
  border-left: 8rpx solid currentColor;
}

/* chevron */
.chevron {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  margin: -6rpx 0 0 -8rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  box-sizing: border-box;
}

/* toolbox */
.tb-body {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 18rpx;
  margin: -4rpx 0 0 -14rpx;
  border-radius: 5rpx;
  background: currentColor;
}

.tb-handle {
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 14rpx;
  height: 8rpx;
  margin-left: -7rpx;
  border: 3rpx solid currentColor;
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
  box-sizing: border-box;
}

.fire text {
  font-size: 28rpx;
  line-height: 1;
}

.dot::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  margin: -4rpx 0 0 -4rpx;
  border-radius: 50%;
  background: currentColor;
}
