<view class="tool-icon-wrap {{colorClass}} size-{{size}} variant-{{variant}}" style="{{colorStyle}}">
  <!-- 图片压缩 -->
  <view wx:if="{{type === 'compress'}}" class="icon compress">
    <view class="compress-frame"></view>
    <view class="compress-hill"></view>
    <view class="compress-hill small"></view>
    <view class="compress-dot"></view>
  </view>
  <!-- 图片裁剪 -->
  <view wx:elif="{{type === 'crop'}}" class="icon crop">
    <view class="crop-frame"></view>
    <view class="crop-corner tl"></view>
    <view class="crop-corner tr"></view>
    <view class="crop-corner bl"></view>
    <view class="crop-corner br"></view>
  </view>
  <!-- 文字提取 -->
  <view wx:elif="{{type === 'text'}}" class="icon text">
    <text class="text-letter">T</text>
  </view>
  <!-- 单位换算 -->
  <view wx:elif="{{type === 'unit'}}" class="icon unit">
    <view class="unit-screen"></view>
    <view class="unit-btn b1"></view>
    <view class="unit-btn b2"></view>
    <view class="unit-btn b3"></view>
  </view>
  <!-- 格式转换 -->
  <view wx:elif="{{type === 'format'}}" class="icon format">
    <view class="format-ring"></view>
    <view class="format-arrow"></view>
  </view>
  <!-- 二维码 -->
  <view wx:elif="{{type === 'qrcode'}}" class="icon qrcode">
    <view class="qr-block tl"></view>
    <view class="qr-block tr"></view>
    <view class="qr-block bl"></view>
    <view class="qr-dot d1"></view>
    <view class="qr-dot d2"></view>
    <view class="qr-dot d3"></view>
  </view>
  <!-- 大小写转换 -->
  <view wx:elif="{{type === 'case'}}" class="icon case">
    <text class="case-a">A</text>
    <text class="case-b">a</text>
  </view>
  <!-- 时间计算 -->
  <view wx:elif="{{type === 'time'}}" class="icon time">
    <view class="time-face"></view>
    <view class="time-hand h"></view>
    <view class="time-hand m"></view>
  </view>
  <!-- 随机数 -->
  <view wx:elif="{{type === 'random'}}" class="icon random">
    <view class="dice-face"></view>
    <view class="dice-dot d1"></view>
    <view class="dice-dot d2"></view>
    <view class="dice-dot d3"></view>
  </view>
  <!-- 颜色转换 -->
  <view wx:elif="{{type === 'color'}}" class="icon color">
    <view class="color-drop"></view>
  </view>
  <!-- BMI -->
  <view wx:elif="{{type === 'bmi'}}" class="icon bmi">
    <view class="bmi-heart"></view>
  </view>
  <!-- 记账 -->
  <view wx:elif="{{type === 'wallet'}}" class="icon wallet">
    <view class="wallet-body"></view>
    <view class="wallet-flap"></view>
  </view>
  <!-- 水印 -->
  <view wx:elif="{{type === 'watermark'}}" class="icon watermark">
    <view class="wm-stamp"></view>
    <text class="wm-text">印</text>
  </view>
  <!-- 图片打码 -->
  <view wx:elif="{{type === 'mosaic'}}" class="icon mosaic">
    <view class="mosaic-grid">
      <view class="mosaic-cell c1"></view>
      <view class="mosaic-cell c2"></view>
      <view class="mosaic-cell c3"></view>
      <view class="mosaic-cell c4"></view>
    </view>
  </view>
  <!-- 拼图排版 -->
  <view wx:elif="{{type === 'layout'}}" class="icon layout">
    <view class="layout-cell c1"></view>
    <view class="layout-cell c2"></view>
    <view class="layout-cell c3"></view>
    <view class="layout-cell c4"></view>
  </view>
  <!-- 数字大写 -->
  <view wx:elif="{{type === 'number'}}" class="icon number">
    <text class="number-char">壹</text>
  </view>
  <!-- 图片编辑 -->
  <view wx:elif="{{type === 'edit'}}" class="icon edit">
    <view class="edit-img"></view>
    <view class="edit-pen"></view>
  </view>
  <!-- 工具箱 -->
  <view wx:elif="{{type === 'toolbox'}}" class="icon toolbox">
    <view class="tb-body"></view>
    <view class="tb-handle"></view>
    <view class="tb-latch"></view>
  </view>
  <!-- 更多 -->
  <view wx:elif="{{type === 'more'}}" class="icon more">
    <view class="more-dot d1"></view>
    <view class="more-dot d2"></view>
    <view class="more-dot d3"></view>
  </view>
  <!-- 默认 -->
  <view wx:else class="icon default">
    <view class="default-dot"></view>
  </view>
</view>
