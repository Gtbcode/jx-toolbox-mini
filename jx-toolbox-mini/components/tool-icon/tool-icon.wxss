.tool-icon-wrap {
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 10rpx 22rpx rgba(10, 123, 255, .18);
}

.tool-icon-wrap.size-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
}

.tool-icon-wrap.size-xs {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
}

.tool-icon-wrap.size-md {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
}

.tool-icon-wrap.size-lg {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
}

.tool-icon-wrap.size-xl {
  width: 118rpx;
  height: 118rpx;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 34rpx rgba(10, 123, 255, .22);
}

.tool-icon-wrap.blue { background: linear-gradient(135deg, #0A7BFF, #20C9FF); }
.tool-icon-wrap.green { background: linear-gradient(135deg, #16C79A, #30D587); }
.tool-icon-wrap.red { background: linear-gradient(135deg, #FF4F67, #FF7A59); }
.tool-icon-wrap.orange { background: linear-gradient(135deg, #FF9D2E, #FFD166); }
.tool-icon-wrap.purple { background: linear-gradient(135deg, #665BFF, #9D6BFF); }
.tool-icon-wrap.cyan { background: linear-gradient(135deg, #12B8D8, #20D8C2); }

.icon {
  position: relative;
  width: 100%;
  height: 100%;
}

/* compress */
.compress-frame {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 40rpx;
  height: 32rpx;
  margin: -16rpx 0 0 -20rpx;
  border-radius: 7rpx;
  border: 3rpx solid rgba(255, 255, 255, .95);
  box-sizing: border-box;
  background: rgba(255, 255, 255, .18);
}

.compress-hill {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  width: 0;
  height: 0;
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-bottom: 11rpx solid rgba(255, 255, 255, .95);
}

.compress-hill.small {
  left: 30rpx;
  border-left-width: 7rpx;
  border-right-width: 7rpx;
  border-bottom-width: 9rpx;
}

.compress-dot {
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .95);
}

.size-lg .compress-frame {
  width: 48rpx;
  height: 38rpx;
  margin: -19rpx 0 0 -24rpx;
}

.size-lg .compress-hill {
  left: 22rpx;
  bottom: 20rpx;
}

.size-lg .compress-hill.small {
  left: 36rpx;
}

.size-lg .compress-dot {
  right: 20rpx;
  top: 18rpx;
}

/* crop */
.crop-frame {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  margin: -15rpx 0 0 -15rpx;
  border: 3rpx solid rgba(255, 255, 255, .35);
  border-radius: 4rpx;
}

.crop-corner {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-color: #FFFFFF;
  border-style: solid;
}

.crop-corner.tl { left: 14rpx; top: 14rpx; border-width: 3rpx 0 0 3rpx; border-radius: 3rpx 0 0 0; }
.crop-corner.tr { right: 14rpx; top: 14rpx; border-width: 3rpx 3rpx 0 0; border-radius: 0 3rpx 0 0; }
.crop-corner.bl { left: 14rpx; bottom: 14rpx; border-width: 0 0 3rpx 3rpx; border-radius: 0 0 0 3rpx; }
.crop-corner.br { right: 14rpx; bottom: 14rpx; border-width: 0 3rpx 3rpx 0; border-radius: 0 0 3rpx 0; }

/* text */
.text-letter {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.size-lg .text-letter { font-size: 42rpx; }

/* unit */
.unit-screen {
  position: absolute;
  left: 50%;
  top: 12rpx;
  width: 34rpx;
  height: 16rpx;
  margin-left: -17rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, .9);
}

.unit-btn {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, .85);
}

.unit-btn.b1 { left: 16rpx; bottom: 16rpx; }
.unit-btn.b2 { left: 50%; bottom: 16rpx; margin-left: -4rpx; }
.unit-btn.b3 { right: 16rpx; bottom: 16rpx; }

/* format */
.format-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  margin: -14rpx 0 0 -14rpx;
  border: 4rpx solid rgba(255, 255, 255, .35);
  border-radius: 50%;
}

.format-arrow {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid #FFFFFF;
  border-right: 4rpx solid #FFFFFF;
  border-radius: 0 4rpx 0 0;
  transform: rotate(45deg);
}

/* qrcode */
.qr-block {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 2rpx;
  box-sizing: border-box;
}

.qr-block.tl { left: 14rpx; top: 14rpx; }
.qr-block.tr { right: 14rpx; top: 14rpx; }
.qr-block.bl { left: 14rpx; bottom: 14rpx; }

.qr-dot {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #FFFFFF;
  border-radius: 1rpx;
}

.qr-dot.d1 { right: 18rpx; bottom: 18rpx; }
.qr-dot.d2 { right: 28rpx; bottom: 18rpx; }
.qr-dot.d3 { right: 18rpx; bottom: 28rpx; }

/* case */
.case-a {
  position: absolute;
  left: 14rpx;
  top: 12rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.case-b {
  position: absolute;
  right: 12rpx;
  bottom: 10rpx;
  color: rgba(255, 255, 255, .85);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

/* time */
.time-face {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 32rpx;
  height: 32rpx;
  margin: -16rpx 0 0 -16rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
  box-sizing: border-box;
}

.time-hand {
  position: absolute;
  left: 50%;
  top: 50%;
  background: #FFFFFF;
  border-radius: 2rpx;
  transform-origin: bottom center;
}

.time-hand.h {
  width: 3rpx;
  height: 10rpx;
  margin: -10rpx 0 0 -1.5rpx;
}

.time-hand.m {
  width: 3rpx;
  height: 12rpx;
  margin: -12rpx 0 0 -1.5rpx;
  transform: rotate(90deg);
}

/* random */
.dice-face {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  margin: -15rpx 0 0 -15rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, .92);
}

.dice-dot {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #12B8D8;
}

.dice-dot.d1 { left: 18rpx; top: 18rpx; }
.dice-dot.d2 { left: 50%; top: 50%; margin: -3rpx 0 0 -3rpx; }
.dice-dot.d3 { right: 18rpx; bottom: 18rpx; }

/* color */
.color-drop {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 28rpx;
  margin: -14rpx 0 0 -11rpx;
  border-radius: 50% 50% 50% 0;
  background: #FFFFFF;
  transform: rotate(-45deg);
}

/* bmi */
.bmi-heart {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  margin: -12rpx 0 0 -12rpx;
  background: #FFFFFF;
  transform: rotate(-45deg);
  border-radius: 0 0 0 8rpx;
}

.bmi-heart::before,
.bmi-heart::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.bmi-heart::before { top: -12rpx; left: 0; }
.bmi-heart::after { top: 0; left: 12rpx; }

/* wallet */
.wallet-body {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 24rpx;
  margin: -8rpx 0 0 -17rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, .92);
}

.wallet-flap {
  position: absolute;
  left: 50%;
  top: 14rpx;
  width: 34rpx;
  height: 10rpx;
  margin-left: -17rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: rgba(255, 255, 255, .65);
}

/* watermark */
.wm-stamp {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 32rpx;
  height: 32rpx;
  margin: -16rpx 0 0 -16rpx;
  border: 3rpx solid rgba(255, 255, 255, .85);
  border-radius: 50%;
  box-sizing: border-box;
}

.wm-text {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 900;
}

/* mosaic */
.mosaic-grid {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 34rpx;
  margin: -17rpx 0 0 -17rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4rpx;
}

.mosaic-cell {
  border-radius: 2rpx;
  background: rgba(255, 255, 255, .92);
}

.mosaic-cell.c1 { opacity: .95; }
.mosaic-cell.c2 { opacity: .72; }
.mosaic-cell.c3 { opacity: .58; }
.mosaic-cell.c4 { opacity: .85; }

/* layout */
.layout-cell {
  position: absolute;
  background: rgba(255, 255, 255, .9);
  border-radius: 3rpx;
}

.layout-cell.c1 { left: 14rpx; top: 14rpx; width: 14rpx; height: 18rpx; }
.layout-cell.c2 { right: 14rpx; top: 14rpx; width: 18rpx; height: 14rpx; }
.layout-cell.c3 { left: 14rpx; bottom: 14rpx; width: 18rpx; height: 14rpx; }
.layout-cell.c4 { right: 14rpx; bottom: 14rpx; width: 14rpx; height: 18rpx; }

/* number */
.number-char {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 900;
}

/* edit */
.edit-img {
  position: absolute;
  left: 14rpx;
  top: 16rpx;
  width: 24rpx;
  height: 20rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, .85);
}

.edit-pen {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 16rpx;
  height: 4rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
  transform: rotate(-45deg);
}

/* toolbox */
.tb-body {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 24rpx;
  margin: -6rpx 0 0 -17rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, .92);
}

.tb-handle {
  position: absolute;
  left: 50%;
  top: 12rpx;
  width: 18rpx;
  height: 10rpx;
  margin-left: -9rpx;
  border: 3rpx solid rgba(255, 255, 255, .92);
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
  box-sizing: border-box;
}

.tb-latch {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 6rpx;
  margin: -2rpx 0 0 -5rpx;
  border-radius: 3rpx;
  background: #0A7BFF;
}

/* more */
.more-dot {
  position: absolute;
  top: 50%;
  width: 5rpx;
  height: 5rpx;
  margin-top: -2.5rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .95);
}

.more-dot.d1 { left: 14rpx; }
.more-dot.d2 { left: 50%; margin-left: -2.5rpx; }
.more-dot.d3 { right: 14rpx; }

.size-xs .more-dot {
  width: 4rpx;
  height: 4rpx;
  margin-top: -2rpx;
}

.size-xs .more-dot.d1 { left: 12rpx; }
.size-xs .more-dot.d2 { margin-left: -2rpx; }
.size-xs .more-dot.d3 { right: 12rpx; }

.variant-soft .more-dot {
  background: var(--tone);
}

/* default */
.default-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  margin: -8rpx 0 0 -8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .9);
}

/* soft variant - light background + colored glyph */
.tool-icon-wrap.variant-soft {
  box-shadow: none;
  border: 1rpx solid rgba(226, 232, 240, .75);
}

.variant-soft.blue { --tone: #0A7BFF; --tone-bg: #EBF4FF; --tone-border: #D6E8FF; }
.variant-soft.green { --tone: #16C79A; --tone-bg: #E8FAF3; --tone-border: #C8F0E2; }
.variant-soft.red { --tone: #FF4F67; --tone-bg: #FFEDF0; --tone-border: #FFD6DC; }
.variant-soft.orange { --tone: #FF9D2E; --tone-bg: #FFF4E5; --tone-border: #FFE4BF; }
.variant-soft.purple { --tone: #665BFF; --tone-bg: #F0EDFF; --tone-border: #DDD6FF; }
.variant-soft.cyan { --tone: #12B8D8; --tone-bg: #E5FAFA; --tone-border: #C4F0F0; }

.tool-icon-wrap.variant-soft:not(.hex-tone) {
  background: var(--tone-bg) !important;
  border-color: var(--tone-border);
  color: var(--tone);
}

.variant-soft .compress-frame {
  border-color: var(--tone);
  background: rgba(255, 255, 255, .72);
}

.variant-soft .compress-hill {
  border-bottom-color: var(--tone);
}

.variant-soft .compress-dot {
  background: var(--tone);
}

.variant-soft .crop-frame {
  border-color: rgba(10, 123, 255, .18);
}

.variant-soft .crop-corner {
  border-color: var(--tone);
}

.variant-soft .text-letter,
.variant-soft .case-a,
.variant-soft .number-char,
.variant-soft .wm-text {
  color: var(--tone);
}

.variant-soft .case-b {
  color: var(--tone);
  opacity: .62;
}

.variant-soft .unit-screen,
.variant-soft .unit-btn,
.variant-soft .format-ring,
.variant-soft .format-arrow,
.variant-soft .qr-block,
.variant-soft .qr-dot,
.variant-soft .time-face,
.variant-soft .time-hand,
.variant-soft .dice-face,
.variant-soft .dice-dot,
.variant-soft .color-drop,
.variant-soft .bmi-heart,
.variant-soft .bmi-heart::before,
.variant-soft .bmi-heart::after,
.variant-soft .wallet-body,
.variant-soft .wallet-flap,
.variant-soft .wm-stamp,
.variant-soft .layout-cell,
.variant-soft .edit-img,
.variant-soft .edit-pen,
.variant-soft .tb-body,
.variant-soft .default-dot {
  background: var(--tone);
}

.variant-soft .format-ring {
  border-color: var(--tone);
  background: transparent;
}

.variant-soft .format-arrow {
  border-color: var(--tone);
  background: transparent;
}

.variant-soft .qr-block {
  background: transparent;
  border-color: var(--tone);
}

.variant-soft .time-face {
  background: transparent;
  border-color: var(--tone);
}

.variant-soft .dice-face {
  background: rgba(255, 255, 255, .88);
}

.variant-soft .dice-dot {
  background: var(--tone);
}

.variant-soft .wm-stamp {
  background: transparent;
  border-color: var(--tone);
}

.variant-soft .tb-handle {
  border-color: var(--tone);
}

.variant-soft .tb-latch {
  background: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft {
  box-shadow: none;
  border: 1rpx solid rgba(226, 232, 240, .75);
}

.tool-icon-wrap.hex-tone.variant-soft .compress-frame {
  border-color: var(--tone);
  background: rgba(255, 255, 255, .72);
}

.tool-icon-wrap.hex-tone.variant-soft .compress-hill {
  border-bottom-color: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .compress-dot {
  background: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .text-letter,
.tool-icon-wrap.hex-tone.variant-soft .case-a,
.tool-icon-wrap.hex-tone.variant-soft .number-char,
.tool-icon-wrap.hex-tone.variant-soft .wm-text {
  color: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .case-b {
  color: var(--tone);
  opacity: .62;
}

.tool-icon-wrap.hex-tone.variant-soft .crop-corner,
.tool-icon-wrap.hex-tone.variant-soft .format-arrow,
.tool-icon-wrap.hex-tone.variant-soft .qr-dot,
.tool-icon-wrap.hex-tone.variant-soft .time-hand,
.tool-icon-wrap.hex-tone.variant-soft .dice-dot,
.tool-icon-wrap.hex-tone.variant-soft .color-drop,
.tool-icon-wrap.hex-tone.variant-soft .bmi-heart,
.tool-icon-wrap.hex-tone.variant-soft .wallet-body,
.tool-icon-wrap.hex-tone.variant-soft .layout-cell,
.tool-icon-wrap.hex-tone.variant-soft .edit-img,
.tool-icon-wrap.hex-tone.variant-soft .default-dot,
.tool-icon-wrap.hex-tone.variant-soft .more-dot {
  background: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .crop-frame {
  border-color: rgba(15, 23, 42, .12);
}

.tool-icon-wrap.hex-tone.variant-soft .format-ring,
.tool-icon-wrap.hex-tone.variant-soft .qr-block,
.tool-icon-wrap.hex-tone.variant-soft .time-face,
.tool-icon-wrap.hex-tone.variant-soft .wm-stamp {
  border-color: var(--tone);
  background: transparent;
}

.tool-icon-wrap.hex-tone.variant-soft .format-arrow {
  background: transparent;
}

.tool-icon-wrap.hex-tone.variant-soft .unit-screen,
.tool-icon-wrap.hex-tone.variant-soft .unit-btn,
.tool-icon-wrap.hex-tone.variant-soft .dice-face,
.tool-icon-wrap.hex-tone.variant-soft .wallet-flap,
.tool-icon-wrap.hex-tone.variant-soft .edit-pen,
.tool-icon-wrap.hex-tone.variant-soft .tb-body {
  background: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .text-letter,
.tool-icon-wrap.hex-tone.variant-soft .case-a,
.tool-icon-wrap.hex-tone.variant-soft .number-char,
.tool-icon-wrap.hex-tone.variant-soft .wm-text {
  background: transparent;
}

.tool-icon-wrap.hex-tone.variant-soft .bmi-heart::before,
.tool-icon-wrap.hex-tone.variant-soft .bmi-heart::after {
  background: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .tb-handle {
  border-color: var(--tone);
}

.tool-icon-wrap.hex-tone.variant-soft .tb-latch {
  background: var(--tone);
}

