.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 116rpx;
  padding: 0 80rpx env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, .96);
  border-top: 1rpx solid rgba(226, 232, 240, .92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -10rpx 34rpx rgba(15, 23, 42, .04);
  z-index: 20;
  box-sizing: border-box;
}

.tab-item {
  min-width: 104rpx;
  height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8A94A6;
  font-size: 22rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9AA4B2;
}

.tab-text {
  margin-top: 6rpx;
  line-height: 1;
}

.tab-item.active {
  color: #0A7BFF;
  font-weight: 800;
}

.tab-item.active .tab-icon {
  color: #0A7BFF;
}

.tab-item:not(.active) .tab-icon {
  color: #9AA4B2;
}

/* 首页 */
.tab-icon-home {
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-shape {
  position: relative;
  width: 28rpx;
  height: 26rpx;
}

.tab-icon-home .home-roof {
  position: absolute;
  left: 50%;
  top: 0;
  width: 0;
  height: 0;
  transform: translateX(-50%);
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 12rpx solid currentColor;
  box-sizing: border-box;
}

.tab-icon-home .home-body {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 20rpx;
  height: 14rpx;
  transform: translateX(-50%);
  border: 3rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
  box-sizing: border-box;
  background: transparent;
}

.tab-item.active .tab-icon-home .home-body {
  background: currentColor;
}

.tab-item:not(.active) .tab-icon-home .home-roof {
  border-bottom-color: #9AA4B2;
}

.tab-item:not(.active) .tab-icon-home .home-body {
  background: #9AA4B2;
  border-color: #9AA4B2;
}

/* 工具 */
.tab-icon-grid {
  display: grid;
  grid-template-columns: repeat(2, 12rpx);
  grid-template-rows: repeat(2, 12rpx);
  gap: 6rpx;
  place-content: center;
}

.grid-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.tab-item:not(.active) .grid-dot {
  background: #9AA4B2;
}

.tab-item.active .grid-dot {
  background: #0A7BFF;
}

/* 我的 */
.tab-icon-user {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon-user .user-head {
  position: absolute;
  top: 8rpx;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  transform: translateX(-50%);
  border-radius: 50%;
}

.tab-icon-user .user-body {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 26rpx;
  height: 14rpx;
  transform: translateX(-50%);
  border-radius: 14rpx 14rpx 8rpx 8rpx;
}

.tab-item:not(.active) .tab-icon-user .user-head,
.tab-item:not(.active) .tab-icon-user .user-body {
  background: #9AA4B2;
}

.tab-item.active .tab-icon-user .user-head,
.tab-item.active .tab-icon-user .user-body {
  background: #0A7BFF;
}
