.home-page {
  padding-top: 88rpx;
}

.brand-head {
  display: flex;
  align-items: center;
  padding: 8rpx 4rpx 24rpx;
}

.brand-logo {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  box-sizing: border-box;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 12rpx 30rpx rgba(10, 123, 255, .18);
}

.brand-logo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.brand-copy {
  margin-left: 24rpx;
}

.brand-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
}

.brand-sub {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.value-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.value-pill {
  height: 58rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #344054;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(20, 63, 115, .05);
  gap: 10rpx;
  padding: 0 8rpx;
}

.pill-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pill-icon.blue {
  background: rgba(10, 123, 255, .1);
}

.pill-icon.green {
  background: rgba(22, 199, 154, .12);
}

.common-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.common-card {
  height: 156rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx 14rpx;
  box-sizing: border-box;
  gap: 14rpx;
}

.common-card .tool-name {
  margin-top: 0;
  font-size: 22rpx;
}

.all-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 28rpx 12rpx;
}

.all-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.all-item .tool-name.small {
  margin-top: 0;
  font-size: 21rpx;
  color: #344054;
  white-space: normal;
  line-height: 1.3;
  max-width: 100%;
}

.safe-card {
  margin-top: 34rpx;
  min-height: 136rpx;
  border-radius: 24rpx;
  padding: 26rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #E9F5FF, #F5FBFF);
  box-shadow: 0 14rpx 34rpx rgba(20, 63, 115, .06);
  box-sizing: border-box;
}

.safe-copy {
  flex: 1;
  min-width: 0;
}

.safe-title {
  color: #0A66E8;
  font-size: 30rpx;
  font-weight: 900;
}

.safe-desc {
  margin-top: 12rpx;
  max-width: 480rpx;
  color: #52647A;
  font-size: 24rpx;
  line-height: 1.55;
}

.safe-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(10, 123, 255, .16);
  background: rgba(255, 255, 255, .95);
  flex-shrink: 0;
  margin-left: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(10, 123, 255, .08);
}

.safe-shield {
  position: relative;
  width: 46rpx;
  height: 52rpx;
}

.safe-shield-body {
  width: 100%;
  height: 100%;
  background: linear-gradient(165deg, #0A7BFF 0%, #35C4FF 100%);
  border-radius: 8rpx 8rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(10, 123, 255, .22);
}

.safe-shield-tick {
  position: absolute;
  left: 50%;
  top: 54%;
  width: 10rpx;
  height: 16rpx;
  border-right: 4rpx solid #FFFFFF;
  border-bottom: 4rpx solid #FFFFFF;
  transform: translate(-50%, -50%) rotate(45deg);
  box-sizing: border-box;
}
