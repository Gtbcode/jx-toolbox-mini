.mine-page {
  padding-top: 88rpx;
}

.profile-card {
  margin-top: 26rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #0A7BFF 0%, #00C6FF 100%);
  box-shadow: 0 18rpx 42rpx rgba(10, 123, 255, .22);
}

.profile-main {
  height: 210rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  color: #FFFFFF;
  position: relative;
}

.profile-main::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .13);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, .13);
  z-index: 2;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.profile-info {
  margin-left: 24rpx;
  flex: 1;
  z-index: 2;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 900;
}

.profile-id {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: .9;
}

.menu-card {
  margin-top: 28rpx;
  padding: 8rpx 0;
}

.menu-item {
  height: 90rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #EEF2F7;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  color: #27364B;
  font-size: 28rpx;
  font-weight: 600;
}

.menu-icon-wrap {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-wrap.color-blue { background: linear-gradient(135deg, #0A7BFF, #20C9FF); }
.menu-icon-wrap.color-red { background: linear-gradient(135deg, #FF4F67, #FF7A59); }
.menu-icon-wrap.color-green { background: linear-gradient(135deg, #16C79A, #30D587); }

.benefit-card {
  margin-top: 34rpx;
  min-height: 150rpx;
  border-radius: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  background: linear-gradient(135deg, #E9F5FF, #F5FBFF);
  box-shadow: 0 14rpx 34rpx rgba(20, 63, 115, .06);
  padding: 20rpx 0;
}

.benefit-item {
  text-align: center;
  border-right: 1rpx solid rgba(190, 208, 230, .7);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.benefit-item:last-child {
  border-right: none;
}

.benefit-title {
  margin-top: 10rpx;
  color: #102033;
  font-size: 24rpx;
  font-weight: 900;
}

.benefit-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 20rpx;
}
